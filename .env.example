# ==============================================================================
# SALIC API Ingestion Pipeline - Example Environment Variables
# ==============================================================================
# Copy this file to '.env' in your deployment directory or load these variables
# directly into your Apache Airflow environment/containers.

# ------------------------------------------------------------------------------
# 1. Active Storage Settings (Local Disk vs MinIO S3 Object Storage)
# ------------------------------------------------------------------------------
# Storage Type Selector:
# - 'local' (default): Saves data to local file system.
# - 's3': Saves data directly to S3-compatible object storage (e.g. MinIO).
SALIC_STORAGE_TYPE=s3

# A. If Local Storage is active:
# Target directory where raw data, manifests, and error reports are stored locally.
# SALIC_RAW_DATA_DIR=raw_data

# B. If S3 / MinIO Storage is active:
# Connection settings for your local or remote MinIO instance.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_BUCKET_NAME=salic

# ------------------------------------------------------------------------------
# 2. Ingestion Settings
# ------------------------------------------------------------------------------
# The maximum number of records to retrieve per API request page.
# Recommended value: 100
SALIC_BATCH_SIZE=100

# Optional limit on the number of batches/iterations per downloader in a single run.
# Leave commented out or empty for unlimited ingestion.
# Setting this to 2, for example, will download a max of 200 records per task
# (2 batches * batch_size of 100), which is highly recommended for test runs!
# SALIC_MAX_OFFSET=5

# Maximum number of retry attempts for API requests experiencing network timeouts
# or server errors before raising a task failure.
SALIC_MAX_RETRIES=3

# The base delay in seconds for request retries.
# The pipeline implements exponential backoff: delay = retry_delay * (2 ** (attempt - 1))
# SALIC_RETRY_DELAY=5
